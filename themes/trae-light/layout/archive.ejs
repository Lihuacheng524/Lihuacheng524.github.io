<section class="archive-page">
  <div class="container">
    <h1 class="page-title">文章归档</h1>
    <% if (page.posts && page.posts.length) { %>
      <% page.posts.each(function(post) { %>
        <article class="archive-post">
          <time datetime="<%= date_xml(post.date) %>" class="archive-date"><%= date(post.date, 'YYYY-MM-DD') %></time>
          <h3 class="archive-title">
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
          </h3>
        </article>
      <% }) %>
    <% } else { %>
      <p class="empty-state">还没有文章</p>
    <% } %>
    <% if (page.total > 1) { %>
      <nav class="pagination">
        <% if (page.prev) { %>
          <a href="<%- url_for(page.prev_link) %>" class="prev">← 上一页</a>
        <% } %>
        <span class="page-number"><%= page.current %> / <%= page.total %></span>
        <% if (page.next) { %>
          <a href="<%- url_for(page.next_link) %>" class="next">下一页 →</a>
        <% } %>
      </nav>
    <% } %>
  </div>
</section>
