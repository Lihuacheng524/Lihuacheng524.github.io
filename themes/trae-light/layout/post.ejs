<article class="post-article">
  <div class="container">
    <div class="post-header">
      <h1 class="post-title"><%= page.title %></h1>
      <div class="post-meta-bar">
        <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'YYYY年MM月DD日') %></time>
        <% if (page.categories && page.categories.length) { %>
          <span class="post-categories">
            <% page.categories.each(function(cat) { %>
              <a href="<%- url_for(cat.path) %>"><%= cat.name %></a>
            <% }) %>
          </span>
        <% } %>
        <% if (page.tags && page.tags.length) { %>
          <span class="post-tags">
            <% page.tags.each(function(tag) { %>
              <a href="<%- url_for(tag.path) %>" class="tag">#<%= tag.name %></a>
            <% }) %>
          </span>
        <% } %>
      </div>
    </div>
    <div class="post-content">
      <%- page.content %>
    </div>
    <nav class="post-nav">
      <div class="post-nav-prev">
        <% if (page.prev) { %>
          <a href="<%- url_for(page.prev.path) %>">← <%= page.prev.title %></a>
        <% } %>
      </div>
      <div class="post-nav-next">
        <% if (page.next) { %>
          <a href="<%- url_for(page.next.path) %>"><%= page.next.title %> →</a>
        <% } %>
      </div>
    </nav>
  </div>
</article>
